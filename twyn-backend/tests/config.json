{
  "step_unit": "month",
  "user_query": "Model consumer adoption of a new electric vehicle in three different income segments. Observe early adopters, price sensitivity, and word-of-mouth effects over the first two years.",
  "agent_groups": {
    "low_income_consumers": {
      "actions": {
        "purchase_decision": {
          "args": {
            "options": [
              "adopt",
              "wait"
            ],
            "__class__": "OptionAction"
          },
          "unit": null,
          "description": "Monthly decision whether to adopt an electric vehicle or continue waiting"
        }
      },
      "variables": {
        "ev_price": {
          "args": {
            "value": 42000,
            "__class__": "InitialValueVariable"
          },
          "unit": "USD",
          "visibility": true,
          "description": "Current market price of electric vehicles, declining over time",
          "update_rule": "np.clip(self.ev_price * 0.985, 30000, 50000)"
        },
        "ev_adopted": {
          "args": {
            "value": 0,
            "__class__": "InitialValueVariable"
          },
          "unit": null,
          "visibility": true,
          "description": "Whether the consumer has adopted an electric vehicle (0=no, 1=yes)",
          "update_rule": "1 if self.purchase_decision == \"adopt\" and self.ev_adopted == 0 else self.ev_adopted"
        },
        "price_sensitivity": {
          "args": {
            "std": 0.1,
            "mean": 0.8,
            "__class__": "NormalVariable"
          },
          "unit": null,
          "visibility": true,
          "description": "Price sensitivity factor (0=not sensitive, 1=very sensitive)",
          "update_rule": null
        },
        "environmental_attitude": {
          "args": {
            "std": 0.12,
            "mean": 0.3,
            "__class__": "NormalVariable"
          },
          "unit": null,
          "visibility": true,
          "description": "Environmental consciousness level (0=low, 1=high)",
          "update_rule": null
        },
        "word_of_mouth_exposure": {
          "args": {
            "value": 0,
            "__class__": "InitialValueVariable"
          },
          "unit": null,
          "visibility": true,
          "description": "Cumulative positive word-of-mouth exposure about EVs from social network",
          "update_rule": "self.word_of_mouth_exposure + 0.05 * np.sum(high_income_consumers.ev_adopted) / 50 + 0.12 * np.sum(middle_income_consumers.ev_adopted) / 100 + 0.08 * np.sum(low_income_consumers.ev_adopted) / 75"
        }
      },
